51, 11, 328, 43250, 35821, 198, 262, 1259, 528, 18162, 24254, 18492, 37, 651, 286, 4505, 4851, 2744, 2129, 37, 651, 286, 7503, 4851, 2744, 487, 328, 37, 651, 286, 56133, 623, 13611, 198, 331, 30038, 26182, 11, 328, 8018, 79898, 35821, 198, 262, 1259, 528, 18162, 24254, 18492, 53959, 2931, 5302, 2129, 53959, 44175, 5567, 5302, 487, 198, 493, 328, 969, 5961, 53959, 2931, 5302, 487, 198, 493, 328, 969, 5961, 53959, 44175, 5567, 5302, 13611, 198, 262, 413, 30038, 9351, 11, 328, 43250, 35821, 198, 285, 1259, 528, 18162, 24254, 18492, 37, 651, 286, 53959, 2931, 5302, 487, 328, 37, 651, 286, 53959, 44175, 5567, 5302, 13611, 271, 2, 6865, 36111, 599, 279, 9144, 314, 524, 21998, 866, 4799, 999, 15933, 11, 198, 2, 5838, 6404, 310, 92547, 13704, 4435, 318, 18092, 11, 781, 1325, 264, 3074, 47685, 553, 198, 331, 30038, 34625, 1052, 11, 359, 47553, 5695, 33782, 198, 262, 696, 5302, 5695, 283, 54154, 1034, 935, 5695, 198, 1449, 25, 198, 262, 696, 5302, 5695, 283, 54154, 14324, 5695, 1358, 1005, 5183, 5302, 25, 271, 262, 4071, 3845, 523, 364, 3421, 6632, 13, 271, 262, 18233, 364, 279, 19260, 25, 271, 262, 471, 1259, 2251, 3676, 3895, 6532, 11, 5952, 2952, 1890, 8, 198, 262, 471, 8418, 34387, 415, 1250, 935, 19916, 28, 15, 13, 20, 8, 198, 262, 471, 23022, 363, 198, 262, 471, 3579, 7644, 363, 220, 653, 413, 488, 635, 524, 958, 8418, 34387, 415, 363, 198, 262, 471, 1408, 11452, 363, 1411, 514, 256, 653, 364, 9089, 271, 262, 18233, 421, 1189, 381, 49724, 25, 271, 262, 471, 3421, 26571, 363, 198, 262, 471, 3421, 65604, 363, 198, 262, 471, 615, 7644, 363, 1411, 1622, 11, 2849, 6532, 198, 262, 471, 3579, 19912, 363, 198, 262, 471, 9845, 7644, 4719, 11, 2849, 6532, 8, 198, 262, 471, 3421, 12340, 363, 198, 262, 471, 1817, 7644, 4719, 11, 2849, 6532, 8, 198, 262, 471, 23022, 7644, 4719, 8, 198, 262, 471, 3160, 7644, 4719, 8, 198, 262, 471, 2393, 24563, 363, 198, 262, 471, 3579, 3960, 363, 271, 262, 18233, 364, 13849, 6632, 25, 271, 262, 471, 6052, 7644, 4719, 11, 2849, 6532, 8, 271, 262, 3124, 7101, 421, 1189, 381, 49724, 539, 13849, 6632, 466, 198, 262, 12740, 25, 271, 262, 471, 9345, 198, 262, 471, 2534, 25966, 198, 262, 471, 7335, 1756, 198, 262, 471, 2070, 1243, 784, 6532, 198, 262, 471, 2070, 1243, 784, 8451, 271, 262, 18700, 7101, 25, 271, 262, 471, 5952, 2952, 1890, 198, 262, 471, 7335, 271, 262, 4071, 271, 262, 9345, 283, 2168, 271, 262, 687, 1259, 2251, 3676, 701, 11, 3421, 6532, 11, 5952, 2952, 1890, 1590, 198, 285, 4071, 12903, 13, 220, 3114, 381, 11244, 11, 635, 524, 2723, 71483, 198, 285, 638, 12275, 6532, 283, 3421, 6532, 198, 285, 638, 9371, 2952, 1890, 283, 5952, 2952, 1890, 198, 285, 638, 4692, 284, 3586, 330, 13596, 283, 29174, 6689, 363, 198, 285, 638, 4692, 57534, 7644, 283, 3439, 271, 262, 687, 271, 8442, 63136, 7827, 1981, 198, 3, 9834, 8418, 6971, 1137, 53109, 220, 19, 198, 58, 20804, 12, 17, 60, 9089, 9393, 12058, 28, 16, 16, 4216, 28, 36114, 12736, 198, 58, 20804, 12, 17, 60, 11330, 4386, 494, 220, 16, 17, 22, 13, 15, 13, 15, 13, 16, 25, 20, 17, 16, 19, 19, 198, 6347, 1371, 318, 3444, 3110, 1562, 1483, 1590, 198, 220, 2793, 328, 12882, 6971, 487, 1500, 220, 23, 23, 11, 303, 696, 30915, 198, 262, 1328, 283, 638, 1385, 8655, 652, 2997, 17084, 8, 198, 220, 2793, 328, 91975, 6971, 487, 1500, 220, 16, 24, 18, 11, 303, 615, 2997, 198, 262, 4673, 36834, 925, 13724, 1152, 2220, 0, 81, 92, 369, 524, 9393, 871, 494, 2168, 198, 1536, 1401, 25, 359, 16, 16, 369, 524, 9393, 6, 271, 21018, 3141, 930, 279, 9626, 13, 12194, 1472, 279, 4222, 5073, 2574, 279, 9089, 11879, 1433, 1245, 1518, 424, 11, 1179, 28647, 264, 13769, 4884, 440, 1970, 13, 4844, 1103, 1330, 29551, 6813, 488, 1000, 884, 13]
