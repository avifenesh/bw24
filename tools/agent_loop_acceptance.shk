#!/usr/bin/env shuck
// 8-turn accumulative agent-loop acceptance protocol.

let model = arg(1) or ""
let out = arg(2) or ""
let arm = arg(3) or ""
if model == "" or out == "" or arm == "" {
  fail("usage: agent_loop_acceptance.shk <model> <out.jsonl> <arm> [extra env...]")
}
let xs = args()
let extra = ""
let i = 3
while i < len(xs) {
  extra = extra + xs[i] + " "
  i = i + 1
}

let root = env("BW24_ROOT") or (env("HOME") + "/projects/bw24")
cd(root)

let k = env("K") or "3"
let ngen = env("NGEN") or "256"
let full_prec = env("FULL_PREC") or "0"
let seed_prompt = env("SEED_PROMPT") or "research/e2e/prompts/p2-code-medium.txt"
let runspec = env("RUNSPEC") or "./target/release/run-spec"
let timeout = env("TIMEOUT") or "900"
let pybin = env("PYBIN") or "python3"
let parse = root + "/tools/acceptance_parse.py"
let corpus_dir = env("CORPUS_DIR") or ""
if corpus_dir != "" { mkdir_p(corpus_dir) }

let turns = [
  "Review this code and list its three biggest problems.",
  "Fix the first problem you listed. Show the full corrected function.",
  "Now add proper error handling to it.",
  "Write unit tests for the corrected function.",
  "One test you wrote is flaky under concurrency. Find it and fix it.",
  "Refactor the module to separate IO from logic.",
  "Document the public API of the refactored module.",
  "Summarize every change made across this session as a changelog."
]

let fp_flag = ""
if full_prec == "1" { fp_flag = "--full-prec" }

let w = sh("mktemp -t agentloop.XXXXXX").text().trim()
sh("cat \"" + seed_prompt + "\" > \"" + w + "\"")

echo("[agent-loop] arm=#{arm} model=#{model} K=#{k} ngen=#{ngen} full_prec=#{full_prec} turns=8")

let turn = 1
for t in turns {
  env("W", w)
  env("TURN", "" + turn)
  env("TMSG", t)
  run("python3", "-c",
    "import os; w=os.environ['W']; tn=int(os.environ['TURN']); m=os.environ['TMSG']; open(w,'a').write(f'\\n\\n### USER TURN {tn}: {m}\\n### ASSISTANT:\\n')"
  ).or_die()
  if corpus_dir != "" {
    cp(w, corpus_dir + "/" + arm + "-agentloop-t" + turn + "-prompt.txt")
  }
  let prec_env = ""
  if full_prec == "1" { prec_env = "BW24_FULL_PREC=1 " }
  let outlog = sh(
    "env " + extra + " " + prec_env +
    "BW24_NGEN=" + ngen + " BW24_SPEC_K=" + k + " BW24_SPEC_STATS=1 BW24_SPEC_HPOST=1 " +
    "BW24_PRINT_TEXT=1 BW24_PROMPT_FILE=" + w + " " +
    "timeout " + timeout + " " + runspec + " " + model + " 2>&1 || true"
  ).text()
  write("/tmp/shuck-agentloop-outlog.txt", outlog)
  sh("awk '/^--- generated text ---$/{f=1;next} /^--- end ---$/{f=0} f' /tmp/shuck-agentloop-outlog.txt >> \"" + w + "\"")
  sh(
    pybin + " " + parse +
    " --out " + out + " --arm " + arm +
    " --prompt agentloop-t" + turn + " --k " + k + " --run 1 --model " + model +
    " --ngen " + ngen + " " + fp_flag +
    " --extra \"agentloop ctx_chars=$(wc -c <" + w + ")\" " +
    "< /tmp/shuck-agentloop-outlog.txt"
  )
  let acc = sh("grep -oE 'acceptance:[^%]*%' /tmp/shuck-agentloop-outlog.txt | head -1 || true").text().trim()
  let ctx = sh("wc -c < \"" + w + "\"").text().trim()
  if acc == "" { acc = "<no acceptance>" }
  echo("[agent-loop] #{arm} turn#{turn} #{acc}  ctx_chars=#{ctx}")
  turn = turn + 1
}
rm(w)
echo("[agent-loop] DONE arm=#{arm} -> #{out}")
