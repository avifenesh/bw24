#!/usr/bin/env shuck
// Build ggml dequant oracle against local llama.cpp.

let ll = env("HOME") + "/projects/llama.cpp"
let here = env("BW24_TOOLS") or (env("HOME") + "/projects/bw24/tools")

run_args([
  "g++", "-O2", "-std=c++17",
  here + "/ggml_dequant_ref.cpp",
  "-o", here + "/ggml_dequant_ref",
  "-I" + ll + "/include",
  "-I" + ll + "/ggml/include",
  "-L" + ll + "/build/bin",
  "-lllama", "-lggml", "-lggml-base"
]).or_die("g++ failed")
echo("built #{here}/ggml_dequant_ref")
